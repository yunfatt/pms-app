        <Parameters isList="true" count="0" />
        <SqlCommand>SELECT vdrno, vdrname, vdrname2, tel, tel2, fax, contact, email, addr1, addr2, addr3, addr4, city, state, postcode, country, groupno, active, accno, creditlimit, term, suppliergst, supplierbrn, tin, bank_code AS bankcode, bank_acctno, remark1, remark2, remark3 FROM vendor WHERE vdrno &gt;= '{VdrNoFrom}' AND vdrno &lt;= '{VdrNoTo}' ORDER BY vdrno</SqlCommand>
      </pms>
