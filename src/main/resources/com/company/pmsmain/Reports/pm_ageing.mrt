        <Parameters isList="true" count="0" />
        <SqlCommand>select a.*,b.custname from f_outstanding_balance('{PropertyNo1}','{PropertyNo2}','{RunDate}',{UseDueDate}) a inner join customer b on a.phaseno=b.phaseno and a.propertyno = b.propertyno and a.custtype = b.custtype</SqlCommand>
