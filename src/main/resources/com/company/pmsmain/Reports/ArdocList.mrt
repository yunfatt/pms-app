        <Parameters isList="true" count="0" />
        <SqlCommand>SELECT trxncode, description, ttype, ptype, billto, deposit, chargeinterest, classification FROM ardoc WHERE trxncode &gt;= '{TrxnCodeFrom}' AND trxncode &lt;= '{TrxnCodeTo}' ORDER BY trxncode</SqlCommand>
