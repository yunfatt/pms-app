        <SqlCommand>SELECT fiscalyear, initdate, finaldate, accperiod, audited, auditedby, auditeddate, periodctrl1, periodctrl2, periodctrl3, periodctrl4, periodctrl5, periodctrl6, periodctrl7, periodctrl8, periodctrl9, periodctrl10, periodctrl11, periodctrl12, periodctrl13, periodctrl14, periodctrl15, periodctrl16, periodctrl17, periodctrl18 FROM glfyear WHERE fiscalyear &gt;= '{FiscalYearFrom}' AND fiscalyear &lt;= '{FiscalYearTo}' ORDER BY fiscalyear</SqlCommand>
