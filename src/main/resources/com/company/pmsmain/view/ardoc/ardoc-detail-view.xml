<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://ardocDetailView.title"
      focusComponent="form">
    <data>
        <instance id="ardocDc"
                  class="com.company.pmsmain.entity.Ardoc">
            <fetchPlan extends="_base"/>
            <loader id="ardocDl"/>
        </instance>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <actions>
        <action id="saveCloseAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <layout>
        <formLayout id="form" dataContainer="ardocDc">
            <responsiveSteps>
                <responsiveStep minWidth="0" columns="1"/>
                <responsiveStep minWidth="40em" columns="2"/>
            </responsiveSteps>

            <textField id="trxncodeField"    property="trxncode"/>
            <textField id="accnoField"       property="accno"/>
            <textField id="autotransferField" property="autotransfer"/>
            <textField id="billtoField"      property="billto"/>
            <textField id="chargeinterestField" property="chargeinterest"/>
            <textField id="cncodeField"      property="cncode"/>
            <textField id="depositField"     property="deposit"/>
            <textField id="descriptionField" property="description"/>
            <textField id="intrateField"     property="intrate"/>
            <textField id="longtermField"    property="longterm"/>
            <textField id="prjnoField"       property="prjno"/>
            <textField id="ptypeField"       property="ptype"/>
            <textField id="readingfromField" property="readingfrom"/>
            <textField id="sinkingfundField" property="sinkingfund"/>
            <textField id="taxcodeidField"   property="taxcodeid"/>
            <textField id="termField"        property="term"/>
            <textField id="ttypeField"       property="ttype"/>
            <textField id="utilityField"     property="utility"/>

            <hbox label="Refund Code" spacing="true" alignItems="CENTER">
                <textField id="refundcodeField"
                           property="refundcode"
                           dataContainer="ardocDc"
                           label=""/>
                <button id="lookupRefundCodeBtn" text="..."/>
            </hbox>

            <hbox label="AP Billing A/C No." spacing="true" alignItems="CENTER">
                <textField id="apaccnoField"
                           property="apaccno"
                           dataContainer="ardocDc"
                           label=""/>
                <button id="lookupApAccNoBtn" text="..."/>
            </hbox>

            <hbox label="Classification" spacing="true" alignItems="CENTER">
                <textField id="classificationField"
                           property="classification"
                           dataContainer="ardocDc"
                           label=""/>
                <button id="lookupClassificationBtn" text="..."/>
            </hbox>

        </formLayout>
        <hbox id="detailActions">
            <button id="saveAndCloseButton" action="saveCloseAction"/>
            <button id="closeButton" action="closeAction"/>
        </hbox>
    </layout>
</view>
