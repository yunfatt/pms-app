<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition"
      title="msg://phaseListView.title"
      focusComponent="searchField">
    <data>
        <collection id="phasesDc"
                    class="com.company.pmsmain.entity.Phase">
            <fetchPlan extends="_base"/>
            <loader id="phasesDl" readOnly="true">
                <query>
                    <![CDATA[select e from Phase e
                 where ((:searchText is null or :searchText = '')
                    or lower(e.phaseno) like lower(concat('%', :searchText, '%'))
                    or lower(e.phasename) like lower(concat('%', :searchText, '%')))
                 order by e.phaseno]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="false"/>
        <urlQueryParameters>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout>

        <!-- ── Search bar ──────────────────────────────────────────────────────── -->
        <hbox width="100%"
              alignItems="CENTER"
              padding="false"
              spacing="true"
              classNames="simple-search-bar">
            <textField id="searchField"
                       placeholder="Search phase no or name..."
                       width="320px"
                       clearButtonVisible="true"/>
            <button id="searchButton"
                    text="Search"
                    themeNames="primary"
                    icon="vaadin:search"/>
            <button id="advancedSearchToggle"
                    text="Advanced"
                    themeNames="tertiary"
                    icon="vaadin:filter"/>
            <!-- Advanced filter inline -->
            <genericFilter id="genericFilter"
                           dataLoader="phasesDl"
                           visible="false">
                <properties include="phaseno phasename area district town prjno"/>
            </genericFilter>
        </hbox>

        <!-- ── Action buttons ──────────────────────────────────────────── -->
        <hbox id="buttonsPanel" classNames="buttons-panel">
            <startSlot>
                <button id="createButton" action="phasesDataGrid.createAction"/>
                <button id="editButton" action="phasesDataGrid.editAction"/>
                <button id="removeButton" action="phasesDataGrid.removeAction"/>
                <button id="printButton"
                        text="msg://phaseListView.printButton"
                        icon="vaadin:print"
                        themeNames="tertiary"/>
            </startSlot>
            <endSlot>
                <simplePagination id="pagination" dataLoader="phasesDl"/>
            </endSlot>
        </hbox>

        <!-- ── Data grid ───────────────────────────────────────────────── -->
        <dataGrid id="phasesDataGrid"
                  width="100%"
                  minHeight="20em"
                  dataContainer="phasesDc"
                  columnReorderingAllowed="true">
            <actions>
                <action id="createAction" type="list_create"/>
                <action id="editAction" type="list_edit"/>
                <action id="removeAction" type="list_remove"/>
            </actions>
            <columns resizable="true">
                <column property="phaseno"/>
                <column property="phasename"/>
                <column property="prjno"/>
                <column property="area"/>
                <column property="district"/>
                <column property="town"/>
                <column property="datestart"/>
                <column property="dateend"/>
            </columns>
        </dataGrid>

        <hbox id="lookupActions" visible="false">
            <button id="selectButton" action="selectAction"/>
            <button id="discardButton" action="discardAction"/>
        </hbox>
    </layout>
</view>