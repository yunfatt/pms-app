<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://glfyearListView.title"
      focusComponent="searchField">
    <data>
        <collection id="glfyearDc"
                    class="com.company.pmsmain.entity.Glfyear">
            <fetchPlan extends="_base"/>
            <loader id="glfyearDl" readOnly="true">
                <query>
                    <![CDATA[select e from Glfyear e
                 where ((:searchText is null or :searchText = '')
                    or lower(e.fiscalyear) like lower(concat('%', :searchText, '%'))
                    or lower(e.auditedby) like lower(concat('%', :searchText, '%')))
                 order by e.id.fiscalyear]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="false"/>
        <urlQueryParameters>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout>

        <!-- ── Search bar ──────────────────────────────────────────────────────── -->
        <hbox width="100%"
              alignItems="CENTER"
              padding="false"
              spacing="true"
              classNames="simple-search-bar">
            <textField id="searchField"
                       placeholder="Search fiscal year or audited by..."
                       width="320px"
                       clearButtonVisible="true"/>
            <button id="searchButton"
                    text="Search"
                    themeNames="primary"
                    icon="vaadin:search"/>
            <button id="advancedSearchToggle"
                    text="Advanced"
                    themeNames="tertiary"
                    icon="vaadin:filter"/>
            <!-- Advanced filter inline -->
            <genericFilter id="genericFilter"
                           dataLoader="glfyearDl"
                           visible="false">
                <properties include=".*"/>
            </genericFilter>
        </hbox>

        <!-- ── Action buttons ──────────────────────────────────────────── -->
        <hbox id="buttonsPanel" classNames="buttons-panel">
            <startSlot>
                <button id="createButton" action="glfyearDataGrid.createAction"/>
                <button id="editButton" action="glfyearDataGrid.editAction"/>
                <button id="removeButton" action="glfyearDataGrid.removeAction"/>
            </startSlot>
            <endSlot>
                <simplePagination id="pagination" dataLoader="glfyearDl"/>
            </endSlot>
        </hbox>

        <!-- ── Data grid ───────────────────────────────────────────────── -->
        <dataGrid id="glfyearDataGrid"
                  width="100%"
                  minHeight="20em"
                  dataContainer="glfyearDc"
                  columnReorderingAllowed="true">
            <actions>
                <action id="createAction" type="list_create"/>
                <action id="editAction" type="list_edit"/>
                <action id="removeAction" type="list_remove"/>
            </actions>
            <columns resizable="true">
                <column property="id.fiscalyear" header="Fiscal Year" width="10em"/>
                <column property="initdate" header="Date From" width="10em"/>
                <column property="finaldate" header="Date To" width="10em"/>
                <column property="accperiod" header="Periods" width="6em"/>
                <column property="audited" header="Audited" width="7em"/>
                <column property="auditedby" header="Audited By" width="12em"/>
                <column property="auditeddate" header="Audited Date" width="10em"/>
            </columns>
        </dataGrid>

        <hbox id="lookupActions" visible="false">
            <button id="selectButton" action="selectAction"/>
            <button id="discardButton" action="discardAction"/>
        </hbox>
    </layout>
</view>
