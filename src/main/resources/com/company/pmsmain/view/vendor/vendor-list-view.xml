<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://vendorListView.title"
      focusComponent="searchField">
    <data>
        <collection id="vendorsDc"
                    class="com.company.pmsmain.entity.Vendor">
            <fetchPlan extends="_base"/>
            <loader id="vendorsDl" readOnly="true">
                <query>
                    <![CDATA[select e from Vendor e
                 where ((:searchText is null or :searchText = '')
                    or lower(e.id.vdrno) like lower(concat('%', :searchText, '%'))
                    or lower(e.vdrname) like lower(concat('%', :searchText, '%'))
                    or lower(e.contact) like lower(concat('%', :searchText, '%')))
                 order by e.id.vdrno]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="false"/>
        <urlQueryParameters>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout>

        <!-- ── Search bar ──────────────────────────────────────────────────────── -->
        <hbox width="100%"
              alignItems="CENTER"
              padding="false"
              spacing="true"
              classNames="simple-search-bar">
            <textField id="searchField"
                       placeholder="Search vendor no, name or contact..."
                       width="320px"
                       clearButtonVisible="true"/>
            <button id="searchButton"
                    text="Search"
                    themeNames="primary"
                    icon="vaadin:search"/>
            <button id="advancedSearchToggle"
                    text="Advanced"
                    themeNames="tertiary"
                    icon="vaadin:filter"/>
            <!-- Advanced filter inline -->
            <genericFilter id="genericFilter"
                           dataLoader="vendorsDl"
                           visible="false">
                <properties include=".*"/>
            </genericFilter>
        </hbox>

        <!-- ── Action buttons ──────────────────────────────────────────── -->
        <hbox id="buttonsPanel" classNames="buttons-panel">
            <startSlot>
                <button id="createButton" action="vendorsDataGrid.createAction"/>
                <button id="editButton" action="vendorsDataGrid.editAction"/>
                <button id="removeButton" action="vendorsDataGrid.removeAction"/>
                <button id="printButton"
                        text="msg://vendorListView.printButton"
                        icon="vaadin:print"
                        themeNames="tertiary"/>
            </startSlot>
            <endSlot>
                <simplePagination id="pagination" dataLoader="vendorsDl"/>
            </endSlot>
        </hbox>

        <!-- ── Data grid ───────────────────────────────────────────────── -->
        <dataGrid id="vendorsDataGrid"
                  width="100%"
                  minHeight="20em"
                  dataContainer="vendorsDc"
                  columnReorderingAllowed="true">
            <actions>
                <action id="createAction" type="list_create"/>
                <action id="editAction" type="list_edit"/>
                <action id="removeAction" type="list_remove"/>
            </actions>
            <columns resizable="true">
                <column property="id.vdrno" header="Vendor No" width="9em"/>
                <column property="vdrname" header="Vendor Name" width="20em"/>
                <column property="vdrname2" header="Vendor Name 2" width="16em"/>
                <column property="tel" header="Tel" width="11em"/>
                <column property="contact" header="Contact Person" width="14em"/>
                <column property="city" header="City" width="10em"/>
                <column property="state" header="State" width="10em"/>
                <column property="groupno" header="Group" width="7em"/>
                <column property="active" header="Active" width="6em"/>
            </columns>
        </dataGrid>

        <hbox id="lookupActions" visible="false">
            <button id="selectButton" action="selectAction"/>
            <button id="discardButton" action="discardAction"/>
        </hbox>
    </layout>
</view>
