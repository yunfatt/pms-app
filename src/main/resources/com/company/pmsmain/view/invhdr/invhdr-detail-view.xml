<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://invhdrDetailView.title"
      focusComponent="form">
    <data>
        <instance id="invhdrDc"
                  class="com.company.pmsmain.entity.Invhdr">
            <fetchPlan extends="_base"/>
            <loader id="invhdrDl"/>
        </instance>

        <collection id="invdtlsDc"
                    class="com.company.pmsmain.entity.Invdtl">
            <fetchPlan extends="_base"/>
            <loader id="invdtlsDl">
                <query>
                    <![CDATA[select e from Invdtl e where e.id.invno = :invno]]>
                </query>
            </loader>
        </collection>
    </data>

    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>

    <actions>
        <action id="closeAction" type="detail_close"/>
    </actions>

    <layout>
        <vbox width="100%" spacing="true">

            <!-- ── Header form ──────────────────────────────────────────── -->
            <formLayout id="form" dataContainer="invhdrDc">
                <responsiveSteps>
                    <responsiveStep minWidth="0"    columns="1"/>
                    <responsiveStep minWidth="40em" columns="2"/>
                    <responsiveStep minWidth="60em" columns="3"/>
                </responsiveSteps>

                <textField id="invnoField"
                           label="Invoice No."
                           readOnly="true"/>

                <hbox label="Property No." spacing="true" alignItems="CENTER">
                    <textField id="propertynoField"
                               property="propertyno"
                               dataContainer="invhdrDc"
                               width="10em"/>
                    <button id="lookupPropertyBtn" text="..."/>
                    <textField id="custnameField"
                               label=""
                               readOnly="true"
                               width="20em"/>
                </hbox>

                <select id="custtypeField"
                        property="custtype"
                        dataContainer="invhdrDc"
                        label="Cust Type"/>

                <datePicker id="trxndateField"
                            property="trxndate"
                            label="Date"/>

                <select id="taxinvtypeField"
                        property="taxinvtype"
                        label="Tax Invoice Type"/>

                <textField id="refnoField"
                           property="refno"
                           label="Ref No"/>

                <textField id="refno2Field"
                           property="refno2"
                           label="Ref No 2"/>

            </formLayout>

            <!-- ── Invoice items ─────────────────────────────────────────── -->
            <h3 text="Invoice Items"/>

            <hbox id="itemActions" spacing="true">
                <button id="addItemBtn"    text="Add Line"/>
                <button id="removeItemBtn" text="Remove Line"/>
                <button id="moveUpBtn"     text="↑" title="Move Up"/>
                <button id="moveDownBtn"   text="↓" title="Move Down"/>
            </hbox>

            <dataGrid id="invdtlsDataGrid"
                      width="100%"
                      minHeight="15em"
                      dataContainer="invdtlsDc">
                <actions>
                    <action id="editLineAction"
                            text="Edit"
                            type="list_edit"
                            openMode="DIALOG"/>
                </actions>
                <columns resizable="true">
                    <column property="id.linenum"  header="Line"            width="60px"/>
                    <column property="chargeno"    header="Code"            width="80px"/>
                    <column property="description" header="Description"     width="200px"/>
                    <column property="date1"       header="From"/>
                    <column property="date2"       header="To"/>
                    <column property="duedate"     header="Due Date"/>
                    <column property="reading1"    header="Initial Reading"/>
                    <column property="reading2"    header="Final Reading"/>
                    <column property="qty"         header="Qty"/>
                    <column property="price"       header="U.P/Amt"/>
                    <column property="netamt"      header="Net Amt"/>
                    <column property="gstamt"      header="GST Amt"/>
                    <column property="amount"      header="Amount"/>
                </columns>
            </dataGrid>

            <!-- ── Totals ────────────────────────────────────────────────── -->
            <formLayout>
                <responsiveSteps>
                    <responsiveStep minWidth="0"    columns="1"/>
                    <responsiveStep minWidth="40em" columns="3"/>
                </responsiveSteps>
                <bigDecimalField id="netamtField"
                                 property="netamt"
                                 dataContainer="invhdrDc"
                                 label="Net Amt"
                                 readOnly="true"/>
                <bigDecimalField id="totalgstField"
                                 property="totalgst"
                                 dataContainer="invhdrDc"
                                 label="Total GST"
                                 readOnly="true"/>
                <bigDecimalField id="amountField"
                                 property="amount"
                                 dataContainer="invhdrDc"
                                 label="Amount"
                                 readOnly="true"/>
            </formLayout>

            <!-- ── Footer actions ────────────────────────────────────────── -->
            <hbox id="detailActions" spacing="true">
                <button id="saveAndCloseButton" text="Save"/>
                <button id="closeButton" action="closeAction"/>
            </hbox>

        </vbox>
    </layout>
</view>