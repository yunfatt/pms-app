<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://customerListView.title"
      focusComponent="searchField">
    <data>
        <collection id="customersDc"
                    class="com.company.pmsmain.entity.Customer">
            <fetchPlan extends="_base"/>
            <loader id="customersDl" readOnly="true">
                <query>
                    <![CDATA[select e from Customer e
                 where ((:searchText is null or :searchText = '')
                    or lower(e.custname) like lower(concat('%', :searchText, '%'))
                    or lower(e.propertyno) like lower(concat('%', :searchText, '%'))
                    or lower(e.phaseno) like lower(concat('%', :searchText, '%'))
                    or lower(e.accno) like lower(concat('%', :searchText, '%')))
                 order by e.phaseno, e.propertyno]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="false"/>
        <urlQueryParameters>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout>

        <hbox width="100%"
              alignItems="CENTER"
              padding="false"
              spacing="true"
              classNames="simple-search-bar">
            <textField id="searchField"
                       placeholder="Search name, property no, phase or acc no..."
                       width="320px"
                       clearButtonVisible="true"/>
            <button id="searchButton"
                    text="Search"
                    themeNames="primary"
                    icon="vaadin:search"/>
            <button id="advancedSearchToggle"
                    text="Advanced"
                    themeNames="tertiary"
                    icon="vaadin:filter"/>
            <genericFilter id="genericFilter"
                           dataLoader="customersDl"
                           visible="false">
                <properties include="phaseno propertyno custtype custname identificationid accno active"/>
            </genericFilter>
        </hbox>

        <hbox id="buttonsPanel" classNames="buttons-panel">
            <startSlot>
                <button id="createButton" action="customersDataGrid.createAction"/>
                <button id="editButton" action="customersDataGrid.editAction"/>
                <button id="removeButton" action="customersDataGrid.removeAction"/>
                <button id="printButton"
                        text="msg://customerListView.printButton"
                        icon="vaadin:print"
                        themeNames="tertiary"/>
            </startSlot>
            <endSlot>
                <simplePagination id="pagination" dataLoader="customersDl"/>
            </endSlot>
        </hbox>

        <dataGrid id="customersDataGrid"
                  width="100%"
                  minHeight="20em"
                  dataContainer="customersDc"
                  columnReorderingAllowed="true">
            <actions>
                <action id="createAction" type="list_create"/>
                <action id="editAction" type="list_edit"/>
                <action id="removeAction" type="list_remove"/>
            </actions>
            <columns resizable="true">
                <column property="phaseno" header="Phase" width="8em"/>
                <column property="propertyno" header="Property No" width="10em"/>
                <column property="custtype" header="Type" width="7em"/>
                <column property="custname" header="Customer Name" width="200px" flexGrow="1"/>
                <column property="identificationid" header="IC/Passport" width="12em"/>
                <column property="tel" header="Tel" width="10em"/>
                <column property="accno" header="Acc No" width="9em"/>
                <column property="active" header="Active" width="7em"/>
            </columns>
        </dataGrid>

        <hbox id="lookupActions" visible="false">
            <button id="selectButton" action="selectAction"/>
            <button id="discardButton" action="discardAction"/>
        </hbox>
    </layout>
</view>
