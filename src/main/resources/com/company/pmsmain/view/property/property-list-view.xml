<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://propertyListView.title"
      focusComponent="searchField">
    <data>
        <collection id="propertiesDc"
                    class="com.company.pmsmain.entity.Property">
            <fetchPlan extends="_base"/>
            <loader id="propertiesDl" readOnly="true">
                <query>
                    <![CDATA[select e from Property e
                 where ((:searchText is null or :searchText = '')
                    or lower(e.propertyno) like lower(concat('%', :searchText, '%'))
                    or lower(e.phaseno) like lower(concat('%', :searchText, '%'))
                    or lower(e.addr1) like lower(concat('%', :searchText, '%')))
                 order by e.phaseno, e.propertyno]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="false"/>
        <urlQueryParameters>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout>

        <hbox width="100%"
              alignItems="CENTER"
              padding="false"
              spacing="true"
              classNames="simple-search-bar">
            <textField id="searchField"
                       placeholder="Search property no, phase or address..."
                       width="320px"
                       clearButtonVisible="true"/>
            <button id="searchButton"
                    text="Search"
                    themeNames="primary"
                    icon="vaadin:search"/>
            <button id="advancedSearchToggle"
                    text="Advanced"
                    themeNames="tertiary"
                    icon="vaadin:filter"/>
            <genericFilter id="genericFilter"
                           dataLoader="propertiesDl"
                           visible="false">
                <properties include="phaseno propertyno addr1 blockno levelno catcode propertystatus"/>
            </genericFilter>
        </hbox>

        <hbox id="buttonsPanel" classNames="buttons-panel">
            <startSlot>
                <button id="createButton" action="propertiesDataGrid.createAction"/>
                <button id="editButton" action="propertiesDataGrid.editAction"/>
                <button id="removeButton" action="propertiesDataGrid.removeAction"/>
                <button id="printButton"
                        text="msg://propertyListView.printButton"
                        icon="vaadin:print"
                        themeNames="tertiary"/>
            </startSlot>
            <endSlot>
                <simplePagination id="pagination" dataLoader="propertiesDl"/>
            </endSlot>
        </hbox>

        <dataGrid id="propertiesDataGrid"
                  width="100%"
                  minHeight="20em"
                  dataContainer="propertiesDc"
                  columnReorderingAllowed="true">
            <actions>
                <action id="createAction" type="list_create"/>
                <action id="editAction" type="list_edit"/>
                <action id="removeAction" type="list_remove"/>
            </actions>
            <columns resizable="true">
                <column property="phaseno" header="Phase" width="8em"/>
                <column property="propertyno" header="Property No" width="10em"/>
                <column property="addr1" header="Address" width="200px" flexGrow="1"/>
                <column property="blockno" header="Block" width="7em"/>
                <column property="levelno" header="Level" width="7em"/>
                <column property="buildup" header="Build Up" width="9em"/>
                <column property="catcode" header="Category" width="8em"/>
                <column property="propertystatus" header="Status" width="7em"/>
            </columns>
        </dataGrid>

        <hbox id="lookupActions" visible="false">
            <button id="selectButton" action="selectAction"/>
            <button id="discardButton" action="discardAction"/>
        </hbox>
    </layout>
</view>
