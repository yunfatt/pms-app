<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="2" author="pms-main">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="glfyear"/></not>
        </preConditions>
        <createTable tableName="glfyear">
            <column name="compno" type="VARCHAR(2)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_GLFYEAR"/>
            </column>
            <column name="fiscalyear" type="VARCHAR(10)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_GLFYEAR"/>
            </column>
            <column name="initdate" type="DATE"/>
            <column name="finaldate" type="DATE"/>
            <column name="accperiod" type="SMALLINT"/>
            <column name="periodctrl1" type="SMALLINT"/>
            <column name="periodctrl2" type="SMALLINT"/>
            <column name="periodctrl3" type="SMALLINT"/>
            <column name="periodctrl4" type="SMALLINT"/>
            <column name="periodctrl5" type="SMALLINT"/>
            <column name="periodctrl6" type="SMALLINT"/>
            <column name="periodctrl7" type="SMALLINT"/>
            <column name="periodctrl8" type="SMALLINT"/>
            <column name="periodctrl9" type="SMALLINT"/>
            <column name="periodctrl10" type="SMALLINT"/>
            <column name="periodctrl11" type="SMALLINT"/>
            <column name="periodctrl12" type="SMALLINT"/>
            <column name="periodctrl13" type="SMALLINT"/>
            <column name="periodctrl14" type="SMALLINT"/>
            <column name="periodctrl15" type="SMALLINT"/>
            <column name="periodctrl16" type="SMALLINT"/>
            <column name="periodctrl17" type="SMALLINT"/>
            <column name="periodctrl18" type="SMALLINT"/>
            <column name="audited" type="SMALLINT"/>
            <column name="auditedby" type="VARCHAR(50)"/>
            <column name="auditeddate" type="DATE"/>
        </createTable>
    </changeSet>
</databaseChangeLog>
